      <div id="progress-bar-bg"><div id="progress-bar"></div></div>
      <span id="round-label">0 / 10</span>
    </div>
  </div>
  <div id="dots"></div>

  <div id="loading-screen">
    <div class="spin"></div>
    <p>Fetching 10 Pokémon from PokéAPI...</p>
  </div>

  <div id="quiz-area">
    <div id="poke-card">
      <div id="poke-top">
        <img id="sprite" alt=""/>
        <div id="poke-meta">
          <div id="poke-num"></div>
          <div id="poke-name"></div>
          <div id="type-row"></div>
          <div id="ability-row">Abilities: <span id="ability-val"></span></div>
        </div>
      </div>
    </div>

    <div id="question-area">
      <div id="q-text"></div>
      <div id="q-sub">Pick the one that does NOT belong to this Pokémon.</div>
      <div id="choices"></div>
    </div>

    <div id="feedback-box">
      <div id="feedback-title"></div>
      <div id="feedback-detail"></div>
    </div>

    <button id="continue-btn" onclick="advance()">
      <div id="btn-inner">
